  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": "{{baseUrl}}/user/code?phone={{phone}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"HTTP 200\", function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test(\"success true\", function () { pm.expect(json.success).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \\\"phone\\\": \\\"{{phone}}\\\",\n  \\\"code\\\": \\\"{{code}}\\\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/user/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"HTTP 200\", function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test(\"success true\", function () { pm.expect(json.success).to.eql(true); });",
                  "pm.collectionVariables.set(\"token\", json.data);",
                  "pm.test(\"token set\", function () { pm.expect(pm.collectionVariables.get(\"token\")).to.not.be.empty; });"
                ]
              }
            }
          ]
        },
