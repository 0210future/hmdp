                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('response has success field', function () { pm.expect(json).to.have.property('success'); });",
                  "if (json && json.data) { pm.collectionVariables.set('login_code', String(json.data)); }"
