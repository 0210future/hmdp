                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/voucher/seckill/{{voucherId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "voucher",
                "seckill",
                "{{voucherId}}"
              ]
            },
            "description": "Optional warm-up request to verify the selected voucherId is valid."
          },
          "response": []
        },
        {
          "name": "Send Code For Dynamic User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dataPhone = pm.iterationData && pm.iterationData.get ? pm.iterationData.get('phone') : null;",
                  "const dataVoucherId = pm.iterationData && pm.iterationData.get ? pm.iterationData.get('voucherId') : null;",
                  "if (dataVoucherId) { pm.collectionVariables.set('voucherId', String(dataVoucherId)); }",
                  "if (dataPhone) {",
                  "  pm.collectionVariables.set('phone', String(dataPhone));",
                  "} else {",
                  "  const prefix = String(pm.collectionVariables.get('phone_prefix') || '139');",
                  "  const iteration = pm.info && typeof pm.info.iteration === 'number' ? pm.info.iteration : 0;",
                  "  const timestampPart = String(Date.now()).slice(-6);",
                  "  const randomPart = String(Math.floor(Math.random() * 1000)).padStart(3, '0');",
                  "  const suffix = (String(iteration).padStart(3, '0') + timestampPart + randomPart).slice(-8);",
                  "  const phone = prefix + suffix;",
                  "  pm.collectionVariables.set('phone', phone);",
                  "}",
                  "pm.collectionVariables.unset('login_code');",
                  "pm.collectionVariables.unset('token');",
                  "pm.collectionVariables.unset('orderId');",
                  "pm.collectionVariables.set('seckill_last_result', 'pending');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('send code success', function () { pm.expect(json.success).to.eql(true); });",
                  "pm.test('login code exists', function () { pm.expect(json.data).to.exist; });",
                  "pm.collectionVariables.set('login_code', String(json.data));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
